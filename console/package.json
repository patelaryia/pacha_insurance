{
  "name": "pacha-console",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run lint && vite build",
    "lint": "tsc --noEmit -p tsconfig.app.json && tsc --noEmit -p tsconfig.node.json",
    "test": "vitest run --config ../tests/acceptance/console/vitest.config.ts",
    "test:coverage": "vitest run --config ../tests/acceptance/console/vitest.config.ts --coverage"
  },
  "dependencies": {
    "@azure/msal-browser": "^4.25.0",
    "@tanstack/react-query": "^5.90.0",
    "lossless-json": "^4.3.0",
    "pdfjs-dist": "^5.4.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-router-dom": "^6.30.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.0",
    "@types/node": "^24.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^5.0.0",
    "@vitest/coverage-v8": "^3.2.0",
    "autoprefixer": "^10.4.0",
    "axe-core": "^4.10.3",
    "jsdom": "^26.1.0",
    "postcss": "^8.5.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.0",
    "vite": "^7.1.0",
    "vitest": "^3.2.0"
  }
}
